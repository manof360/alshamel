# ===========================================
# إعدادات قاعدة البيانات (اختياري)
# ===========================================
# استخدم PostgreSQL للإنتاج على Vercel
# DATABASE_URL="postgresql://user:password@host:5432/alshamel"
# DIRECT_URL="postgresql://user:password@host:5432/alshamel"

# ===========================================
# إعدادات البريد الإلكتروني (Resend)
# ===========================================
# احصل على مفتاح API مجاني من https://resend.com
# RESEND_API_KEY="re_xxxxxxxxxxxx"

# ===========================================
# إعدادات التطبيق
# ===========================================
# NEXT_PUBLIC_APP_URL="https://your-domain.vercel.app"

# ===========================================
# البريد الإلكتروني للإشعارات
# ===========================================
# NOTIFICATION_EMAIL="your-email@example.com"
